{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Codelldb bin",
            "type": "codelldb",
            "request": "launch",
            "program": "build/foo",
            "args": [
                "--aa"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Codelldb attach",
            "type": "codelldb",
            "request": "attach",
            "pid": "${command:pickProcess}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "type": "delve",
            "name": "Debug",
            "request": "launch",
            "console": "integratedTerminal",
            "program": "${file}"
        },
        {
            "type": "delve",
            "name": "Debug test",
            "request": "launch",
            "mode": "test",
            "console": "integratedTerminal",
            "program": "${file}"
        },
        {
            "type": "delve",
            "name": "Debug test (go.mod)",
            "request": "launch",
            "mode": "test",
            "program": "./${relativeFileDirname}",
            "console": "integratedTerminal"
        }
    ],
    "inputs": [
        {
            "id": "myPrompt",
            "type": "promptString",
            "description": "Program to run: ",
            "default": "build/foo"
        },
        {
            "id": "myPick",
            "type": "pickString",
            "description": "Program to run: ",
            "options": [
                "build/foo",
                "build/test/test_5"
            ]
        }
    ]
}
